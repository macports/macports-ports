PortSystem          1.0
PortGroup           golang 1.0

go.setup            github.com/air-verse/air 1.67.1 v
go.offline_build    no
revision            0

description         Live reload for Go apps

long_description    {*}${description}. Just ${name} in your project root \
                    directory, leave it alone, and focus on your code.

categories          devel
installs_libs       no
license             GPL-3
maintainers         {gmail.com:herby.gillot @herbygillot} \
                    openmaintainer

checksums           rmd160  430043bf6b412368248ffab70353b1f2d7dc0953 \
                    sha256  5cefce955beb727e3025cfa10df022d592c3d447a4d55aa62d25080dc5c936f3 \
                    size    1069819

pre-build {
    set go_ver [exec ${go.bin} version]
    regexp {go version go(\S+)} ${go_ver} -> go_compiler_ver
    build.pre_args-append -ldflags=\" \
        -X main.airVersion=${github.tag_prefix}${version} \
        -X main.goVersion=${go_compiler_ver} \
    \"
}

destroot {
    xinstall -m 0755 ${worksrcpath}/${name} ${destroot}${prefix}/bin/
}
