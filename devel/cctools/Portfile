# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*-

PortSystem          1.0

name                cctools
version             1030.6.3
revision            0

categories          devel
license             APSL-2
maintainers         nomaintainer
installs_libs       no
supported_archs     noarch
platforms           {darwin >= 23}

description         Compiler tools for Darwin and macOS
long_description    A set of essential tools to support development on \
                    Darwin and macOS. Conceptually similar to GNU binutils.

homepage            https://github.com/apple-oss-distributions/cctools

# Wrapper-first implementation (same operational model as legacy +xcode):
# use host toolchain through xcrun for maximum compatibility on modern macOS.

distfiles
fetch               {}
checksum            {}
extract             {}
use_configure       no
build               {}

default_variants    +xcode

set cctools_cmds {
    as
    ar
    bitcode_strip
    codesign_allocate
    ctf_insert
    install_name_tool
    libtool
    lipo
    nm
    nm-classic
    nmedit
    otool
    otool-classic
    pagestuff
    ranlib
    segedit
    size
    size-classic
    strings
    strip
    vtool
    objdump
}

variant xcode conflicts xtools description {Use Xcode/CLT supplied cctools} {
    destroot {
        xinstall -d ${destroot}${prefix}/bin
        foreach xcode_cmd ${cctools_cmds} {
            set mp_cmd ${destroot}${prefix}/bin/${xcode_cmd}
            set fd [open ${mp_cmd} "w"]
            puts ${fd} "#!/bin/sh"
            puts ${fd} "if test -x /usr/bin/xcrun; then"
            puts ${fd} "  exec /usr/bin/xcrun ${xcode_cmd} \"\$@\""
            puts ${fd} "elif test -x /usr/bin/${xcode_cmd}; then"
            puts ${fd} "  exec /usr/bin/${xcode_cmd} \"\$@\""
            puts ${fd} "else"
            puts ${fd} "  exec ${xcode_cmd} \"\$@\""
            puts ${fd} "fi"
            close ${fd}
            file attributes ${mp_cmd} -permissions 0755
        }
    }
}

variant xtools conflicts xcode description {Use darwin-xtools as cctools} {
    depends_run      port:darwin-xtools
    destroot {
        xinstall -d ${destroot}${prefix}/bin
        foreach cctool_cmd ${cctools_cmds} {
            ln -s ../libexec/darwin-xtools/bin/${cctool_cmd} \
                ${destroot}${prefix}/bin/${cctool_cmd}
        }
    }
}

livecheck.type      regex
livecheck.url       ${homepage}/tags
livecheck.regex     {cctools-(\d+(?:\.\d+)*)}
