github.setup        sst opencode 1.0.134 v

revision            0
categories          devel
license             MIT
maintainers         @diogom93 openmaintainer

description         Terminal AI coding agent
long_description    OpenCode is an open-source AI coding agent \
                    built for the terminal, with a native TUI, \
                    provider-agnostic model support and strong \
                    integration with modern developer workflows.

homepage            https://opencode.ai/

supported_archs     arm64 x86_64

github.tarball_from releases
use_zip             yes

if {${configure.build_arch} eq "arm64"} {
    # opencode-darwin-arm64.zip
    distname        opencode-darwin-arm64
    checksums       rmd160 58372019502666670211f1ca949f7154969d6fc5 \
                    sha256 2b81005ac5ec5a903cf2d8d3ce0f38c2e1f4f4bc58bf6ed576d5f480d6df48f6 \
                    size 31523493
} elseif {${configure.build_arch} eq "x86_64"} {
    # opencode-darwin-x64.zip (non-baseline)
    distname        opencode-darwin-x64
    checksums       rmd160 959f3c7a4c4b77e1f9d94296344e103ea638a1f2 \
                    sha256 d973b463162c0d22b91e0c616d1ad48f08ae8c3347b3aa1d0ee337c3364c3bf2 \
                    size 33841939
} else {
    ui_error "opencode is only available for arm64 and x86_64"
    return -code error "unsupported architecture ${configure.build_arch}"
}

use_configure       no
build               {}

destroot {
    xinstall -d ${destroot}${prefix}/bin
    xinstall -m 755 ${workpath}/opencode ${destroot}${prefix}/bin/
}
