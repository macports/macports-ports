# User settings for the MacPorts Jenkins startup item.
# This file is sourced by the generated launchd wrapper.
# Changes here are preserved across port upgrades.

JENKINS_HOST=127.0.0.1
JENKINS_PORT=8080

# Additional Java options, for example:
# JENKINS_JAVA_OPTS="-Djava.awt.headless=true"
JENKINS_JAVA_OPTS=

# Additional Jenkins arguments, for example:
# JENKINS_ARGS="--prefix=/jenkins"
JENKINS_ARGS=
