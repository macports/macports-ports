PortSystem          1.0

PortGroup           cargo   1.0
PortGroup           github  1.0

github.setup        EpicGames lore 0.8.3 v
github.tarball_from archive
name                epic-lore
revision            0

homepage            https://epicgames.github.io/lore/

description         \
    Next-generation version control system for code and large binary assets

long_description    \
    {*}${description}. Lore is an open-source version control system designed \
    to handle projects combining code with large binary assets, such as games \
    and entertainment projects. It features content-addressed storage, \
    immutable revision chains, chunked storage for large binary files, and \
    on-demand data hydration.

categories          devel
installs_libs       no
license             MIT
maintainers         {gmail.com:herby.gillot @herbygillot} \
                    openmaintainer

checksums           ${distname}${extract.suffix} \
                    rmd160  27cb5b9c773513d550eae6d5ba4a9fa7e78954c7 \
                    sha256  9973507858ccfa5d8e157b3bb058b29c811fd900fef34eef209db76af705d8d6 \
                    size    3291290

build.args-append   --package lore-client \
                    --package lore-server

destroot {
    foreach bin {lore loreserver} {
        xinstall -m 0755 \
            ${worksrcpath}/target/[cargo.rust_platform]/release/${bin} \
            ${destroot}${prefix}/bin/
    }

    set lore_bin ${worksrcpath}/target/[cargo.rust_platform]/release/lore

    xinstall -d ${destroot}${prefix}/share/bash-completion/completions
    system "${lore_bin} completions bash > ${destroot}${prefix}/share/bash-completion/completions/lore"

    xinstall -d ${destroot}${prefix}/share/zsh/site-functions
    system "${lore_bin} completions zsh > ${destroot}${prefix}/share/zsh/site-functions/_lore"

    xinstall -d ${destroot}${prefix}/share/fish/vendor_completions.d
    system "${lore_bin} completions fish > ${destroot}${prefix}/share/fish/vendor_completions.d/lore.fish"

    xinstall -d ${destroot}${prefix}/share/${name}/examples
    xinstall -m 0644 \
        {*}[glob ${worksrcpath}/lore-server/examples/*.toml] \
        ${destroot}${prefix}/share/${name}/examples/
}

