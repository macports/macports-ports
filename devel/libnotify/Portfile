compiler.c_standard 2023

# Tests require gtk3
configure.args      -Dtests=false

pre-activate {
	if {${os.major} == 11 && ${os.minor} < 2 && ${os.platform} eq "darwin"} {
		ui_error "You must first update to OS X 10.7.2."
		return -code error "You must first update to OS X 10.7.2."
	}
}

