# The bundled vscode-markdown-languageservice uses a default import of
# vscode-uri, which its ESM build no longer provides, so the markdown server
# fails to start under Node. Rewrite it to a namespace import.
post-destroot {
    reinplace "s|import uri from 'vscode-uri'|import * as uri from 'vscode-uri'|" \
        ${destroot}${prefix}/lib/node_modules/${name}/node_modules/vscode-markdown-languageservice/out/util/vscodeUri.js
}
