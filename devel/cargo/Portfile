PortSystem              1.0

PortGroup               github      1.0
PortGroup               cargo       1.0
PortGroup               rust_build  1.0

name                    cargo

if {${os.platform} eq "darwin" && ${os.major} > 16} {
    # (CURRENT) macOS 10.13 and later
    github.setup        rust-lang ${name} 0.97.2
    rust_build.version  1.96.0
    revision            0
} else {
    # macOS 10.12 and earlier
    github.setup        rust-lang ${name} 0.79.0
    rust_build.version  1.78.0
    revision            3

    # NOTE: The mirror_all_architectures variant doesn't currently work with
    # this pinned version.
}

epoch                   1

categories              devel
license                 {MIT Apache-2}
maintainers             {mcalhoun @MarcusCalhoun-Lopez} \
                        openmaintainer

if {${os.platform} eq "darwin" && ${os.major} > 16} {
    supported_archs     arm64 x86_64
} else {
    supported_archs     x86_64 i386
}

description             The Rust package manager

long_description        Cargo downloads your Rust project’s dependencies and \
                        compiles your project.

homepage                https://crates.io
github.tarball_from     archive

rust_build.components   cargo

installs_libs           no

openssl.branch          3

# can use cmake or cmake-devel; default to cmake.
depends_build           port:pkgconfig \
                        path:bin/cmake:cmake

depends_lib             port:curl \
                        path:lib/pkgconfig/libgit2.pc:libgit2 \
                        port:libssh2 \
                        port:zlib

depends_run             port:rust

depends_skip_archcheck-append \
                        pkgconfig \
                        cmake \
                        libgit2 \
                        libssh2

if {${os.platform} eq "darwin" && ${os.major} > 16} {
    # (CURRENT) macOS 10.13 and later
    checksums-append    ${distname}${extract.suffix} \
                        rmd160  2c924d606ed59d9bc6a49b1a4e48ad381ec1cd72 \
                        sha256  5a18618e2d159fed15ff9516aea07ed8232d8cb3cac02224c0f9f8490debe68c \
                        size    5017617
} else {
    # macOS 10.12 and earlier
    checksums-append    ${distname}${extract.suffix} \
                        rmd160  e0c08f36a29d6106648dc183afb8fadfbd75f9df \
                        sha256  b9de52bc7452fd74ab344b636f054de3e9a67cf167567cc4ce948e9219e81d98 \
                        size    3908982
}

# On unsupported hosts, configure.build_arch can be empty while the Portfile is
# still opened for mirroring. Only derive the bootstrap cargo path when there
# is a concrete build architecture.
if {${configure.build_arch} ne ""} {
    lassign             [rust_build.stage0_info ${configure.build_arch}] stage0_version stage0_arch
    cargo.bin           ${workpath}/cargo-${stage0_version}-[option triplet.${stage0_arch}]/cargo/bin/cargo
}

cargo.update            yes

if { ${os.platform} eq "darwin" && ${os.major} < 10 } {
    # CFURLSetResourcePropertyForKey was introduced in 10.6, so turn off the (optional) function that uses it
    patchfiles-append   patch-no_CFURLSetResourcePropertyForKey.diff
}

# Use MacPorts curl
# https://doc.rust-lang.org/cargo/commands/cargo-install.html
# Features of direct dependencies may be enabled with <dep-name>/<feature-name> syntax.
build.args-append       --features curl-sys/force-system-lib-on-osx

destroot {
    xinstall            ${worksrcpath}/target/[cargo.rust_platform]/release/cargo \
                        ${destroot}${prefix}/bin

    xinstall -m 0644    {*}[glob ${worksrcpath}/src/etc/man/*] \
                        ${destroot}${prefix}/share/man/man1

    xinstall -d         ${destroot}${prefix}/share/doc/${subport}
    xinstall -m 0644 -W ${worksrcpath} \
                        LICENSE-APACHE LICENSE-MIT LICENSE-THIRD-PARTY README.md \
                        ${destroot}${prefix}/share/doc/${subport}

    xinstall -d         ${destroot}${prefix}/etc/bash_completion.d
    xinstall -m 0644    ${worksrcpath}/src/etc/cargo.bashcomp.sh \
                        ${destroot}${prefix}/etc/bash_completion.d/${subport}

    xinstall -d         ${destroot}${prefix}/share/zsh/site-functions
    xinstall -m 0644    ${worksrcpath}/src/etc/_cargo \
                        ${destroot}${prefix}/share/zsh/site-functions
}

