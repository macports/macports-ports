build.args-append   -ldflags=\" \
                        -X 'main.version=${github.tag_prefix}${version}' \
                        -X 'main.commit=${git-commit}' \
                        -X 'main.buildSource=MacPorts' \
                        -X 'main.date=not set' \
                    \" -o ./${name} .

destroot {
    xinstall -m 0755 ${worksrcpath}/${name} ${destroot}${prefix}/bin/
