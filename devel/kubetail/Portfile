# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

# Portfile
PortSystem          1.0
PortGroup           github 1.0

# ── Basic metadata ─────────────────────────────────────────────────────────────
name                kubetail
version             0.8.2
categories          devel
license             Apache-2
maintainers         {kubetail.com:andres @amorey} openmaintainer

description         Real-time logging tool for Kubernetes
long_description    Kubetail is a general-purpose logging tool for Kubernetes, optimized \
                    for tailing logs across multi-container workloads in real-time. With \
                    Kubetail, you can view logs from all the containers in a workload \
                    merged into a single, chronological timeline, delivered to your \
                    browser or terminal.

homepage            https://github.com/kubetail-org/${name}

# ── Livecheck (use GitHub releases/tags) ───────────────────────────────────────
livecheck.type      github
livecheck.regex     {^cli/v?(\d+\.\d+\.\d+)$}

# ── Default: GitHub source tarball (works for the +source variant) ─────────────
github.setup        kubetail-org ${name} ${version} cli/v
github.tarball_from tarball

checksums           rmd160  5f9137bc9e29d8c0e8d12090f0b9c9832ed3c6e9 \
                    sha256  3933b6ca540252bee8ece2b180480ca8cebf92388c361b4fd50a471787e54111 \
                    size    613899

# Keep configure off
use_configure       no

# ── Variants ───────────────────────────────────────────────────────────────────
# +source  : build from sources (default behavior of this Portfile)
# +binary  : fetch and install a prebuilt executable packaged as a gzip tarball from GitHub Releases

variant source description {Build from source (default GitHub source archive)} {
    build.cmd           make
    build.target        build
    build.args-append   VERSION=${version}

    depends_build-append port:go port:pnpm

    destroot {
        xinstall -m 0755 ${worksrcpath}/bin/kubetail ${destroot}${prefix}/bin/kubetail

        # Copy license
        xinstall -d ${destroot}${prefix}/share/doc/${name}
        if {[file exists ${worksrcpath}/LICENSE]} {
            xinstall -m 0644 ${worksrcpath}/LICENSE ${destroot}${prefix}/share/doc/${name}/
        }
    }
}

variant binary description {Install prebuilt executable from GitHub Releases (gzipped tarball)} {
    switch -exact ${build_arch} {
        arm64 {
            set asset_name   "kubetail-darwin-arm64.tar.gz"
            set asset_sha256 16cff715047edc7a76c290e286bce61ec6cc9efa0af368a36f2e9c03f64b5335
            set asset_rmd160 6edbb7802f21f0eec3844b3aa691faddb71202cc
            set asset_size   23471937
        }
        x86_64 {
            set asset_name   "kubetail-darwin-amd64.tar.gz"
            set asset_sha256 c39b690b92c6058eb2885439bf195dd94f22444a8fa66b9a98493a681ad89dea
            set asset_rmd160 57c31861bdb0b76acdf43b9b16775329a2cdbad6
            set asset_size   25062959
        }
        default {
            ui_error "${name}: no binary available for ${build_arch}"
            return -code error "unsupported architecture"
        }
    }

    # Point fetching to the GitHub Releases asset URL instead of the source archive.
    master_sites    https://github.com/kubetail-org/${name}/releases/download/cli%2Fv${version}
    distfiles       ${asset_name}
    extract.rename  no

    # Provide checksums for the *binary* tarball (override the default one used for source).
    checksums       rmd160  ${asset_rmd160} \
                    sha256  ${asset_sha256} \
                    size    ${asset_size}

    # No configure or build steps for a prebuilt binary
    use_configure   no
    build           {}

    destroot {
        xinstall -m 0755 ${workpath}/${name} ${destroot}${prefix}/bin/kubetail

        # Copy license
        xinstall -d ${destroot}${prefix}/share/doc/${name}
        if {[file exists ${workpath}/LICENSE]} {
            xinstall -m 0644 ${workpath}/LICENSE ${destroot}${prefix}/share/doc/${name}/
        }
    }
}

# Set default variant to +source
default_variants +source

# ── Platform hints ----------──────────────────────────────────────────────────
supported_archs     arm64 x86_64
if {![variant_isset source]} {
    # Skip universal variant for binary installs
    universal_variant no
}
