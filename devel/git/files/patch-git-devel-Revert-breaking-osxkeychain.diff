-		if (!strcmp(state_seen, sb.buf)) {
-			strbuf_release(&sb);
-			return errSecSuccess;
-		}
-		strbuf_release(&sb);
-	}
-
-	data = CFDataCreateMutableCopy(kCFAllocatorDefault, 0, password);
