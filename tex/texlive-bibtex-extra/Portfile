texlive.binaries    bbl2bib bib2gls bibcop bibdoiadd bibexport bibmradd biburl2doi bibzbladd citeproc-lua convertgls2bib datatool2bib listbib ltx2crossrefxml ltx2unitxt multibibliography urlbst

# These scripts compute their location based on TEXMFROOT which is not
# correct for our installation. Patch in the correct path.
patchfiles-append \
    patch-runfiles_texmf-dist_scripts_bibtexperllibs_ltx2unitxt.diff \
    patch-runfiles_texmf-dist_scripts_crossrefware_bbl2bib.pl.diff \
    patch-runfiles_texmf-dist_scripts_crossrefware_bibdoiadd.pl.diff \
    patch-runfiles_texmf-dist_scripts_crossrefware_bibmradd.pl.diff \
    patch-runfiles_texmf-dist_scripts_crossrefware_biburl2doi.pl.diff \
    patch-runfiles_texmf-dist_scripts_crossrefware_bibzbladd.pl.diff \
    patch-runfiles_texmf-dist_scripts_crossrefware_ltx2crossrefxml.pl.diff

post-patch {
    foreach f { \
        runfiles/texmf-dist/scripts/bibtexperllibs/ltx2unitxt \
        runfiles/texmf-dist/scripts/crossrefware/bbl2bib.pl \
        runfiles/texmf-dist/scripts/crossrefware/bibdoiadd.pl \
        runfiles/texmf-dist/scripts/crossrefware/bibmradd.pl \
        runfiles/texmf-dist/scripts/crossrefware/biburl2doi.pl \
        runfiles/texmf-dist/scripts/crossrefware/bibzbladd.pl \
        runfiles/texmf-dist/scripts/crossrefware/ltx2crossrefxml.pl \
    } {
        reinplace "s|@@TEXMFDIST@@|${texlive_texmfdist}|" ${worksrcpath}/${f}
    }

    # Fix perl paths for any perl scripts that have non-core
    # dependencies.
    reinplace -E "1 s,^#! ?(/usr/bin/env perl|/usr/bin/perl),#!${prefix}/bin/perl${perl5.major}," \
        ${worksrcpath}/runfiles/texmf-dist/scripts/crossrefware/bbl2bib.pl \
        ${worksrcpath}/runfiles/texmf-dist/scripts/crossrefware/bibdoiadd.pl \
        ${worksrcpath}/runfiles/texmf-dist/scripts/crossrefware/bibmradd.pl \
        ${worksrcpath}/runfiles/texmf-dist/scripts/crossrefware/bibzbladd.pl
}

PortGroup           perl5 1.0
perl5.branches      5.34

# dependencies for crossrefware (bbl2bib, bibdoiadd, bibmradd, bibzbladd)
depends_run-append  port:p${perl5.major}-libwww-perl \
                    port:p${perl5.major}-uri \
                    port:p${perl5.major}-json


texlive.texmfport
