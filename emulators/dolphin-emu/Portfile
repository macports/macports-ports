PortSystem          1.0

PortGroup           github  1.0
PortGroup           cmake   1.1
PortGroup           qt6     1.0

github.setup        dolphin-emu dolphin 2606
name                dolphin-emu
revision            0

homepage            https://dolphin-emu.org

description         GameCube and Wii emulator

long_description    Dolphin is an emulator for two recent Nintendo video \
                    game consoles: the GameCube and the Wii. It allows PC \
                    gamers to enjoy games for these two consoles in full HD \
                    with several enhancements: compatibility with all PC \
                    controllers, turbo speed, networked multiplayer, and more.

categories          emulators games
license             GPL-2+
maintainers         {gmail.com:herby.gillot @herbygillot} openmaintainer

fetch.type          git

post-fetch {
    system -W ${worksrcpath} "git submodule update --init \
        Externals/cpp-ipc/cpp-ipc \
        Externals/cpp-optparse/cpp-optparse \
        Externals/imgui/imgui \
        Externals/implot/implot \
        Externals/mGBA/mgba \
        Externals/rcheevos/rcheevos \
        Externals/spirv_cross/SPIRV-Cross \
        Externals/tinygltf/tinygltf \
        Externals/watcher/watcher \
    "
}

patchfiles          patch-vulkan-system-headers.diff

compiler.cxx_standard \
                    2023

qt6.depends_lib     qtsvg

depends_build-append \
                    path:bin/pkg-config:pkgconfig

depends_lib-append  port:bzip2 \
                    port:cubeb \
                    port:curl \
                    port:glslang \
                    port:hidapi \
                    port:libenet \
                    port:libfmt12 \
                    port:libiconv \
                    port:libspng \
                    port:libusb \
                    port:lz4 \
                    port:lzo2 \
                    port:mbedtls \
                    port:miniupnpc \
                    port:minizip-ng \
                    port:MoltenVK \
                    port:vulkan-headers \
                    port:vulkan-memory-allocator \
                    port:pugixml \
                    port:SDL3 \
                    port:sfml \
                    port:xxhashlib \
                    port:xz \
                    port:zstd

configure.pkg_config_path-append \
                    ${prefix}/lib/libfmt12/pkgconfig

configure.args-append \
                    -DENABLE_AUTOUPDATE=OFF \
                    -DENABLE_ANALYTICS=OFF \
                    -DENABLE_TESTS=OFF \
                    -DMACOS_CODE_SIGNING=OFF \
                    -DPOSTPROCESS_BUNDLE=OFF \
                    -DUSE_BUNDLED_MOLTENVK=OFF \
                    -DUSE_SYSTEM_BZIP2=ON \
                    -DUSE_SYSTEM_CUBEB=ON \
                    -DUSE_SYSTEM_CURL=ON \
                    -DUSE_SYSTEM_ENET=ON \
                    -DUSE_SYSTEM_FMT=ON \
                    -DUSE_SYSTEM_ICONV=ON \
                    -DUSE_SYSTEM_LIBLZMA=ON \
                    -DUSE_SYSTEM_LIBUSB=ON \
                    -DUSE_SYSTEM_LZ4=ON \
                    -DUSE_SYSTEM_LZO=ON \
                    -DUSE_SYSTEM_MBEDTLS=ON \
                    -DUSE_SYSTEM_MINIUPNPC=ON \
                    -DUSE_SYSTEM_MINIZIP-NG=ON \
                    -DUSE_SYSTEM_PUGIXML=ON \
                    -DUSE_SYSTEM_SPNG=ON \
                    -DUSE_SYSTEM_XXHASH=ON \
                    -DUSE_SYSTEM_ZLIB=ON \
                    -DUSE_SYSTEM_ZSTD=ON \
                    -DUSE_SYSTEM_GLSLANG=ON \
                    -DUSE_SYSTEM_HIDAPI=ON \
                    -DUSE_SYSTEM_SDL3=ON \
                    -DUSE_SYSTEM_SFML=ON

destroot {
    move ${workpath}/build/Binaries/Dolphin.app \
        ${destroot}${applications_dir}/Dolphin.app
}
