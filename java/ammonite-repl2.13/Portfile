# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4
PortSystem          1.0
PortGroup           java 1.0
PortGroup           select 1.0

name                ammonite-repl2.13
version             3.0.9
revision            0
categories          java devel lang
maintainers         nomaintainer
description         Modernized Scala REPL
long_description \
    A Modernized Scala REPL. With syntax highlighting, multi-line editing, the ability \
    to load maven artifacts directly in the REPL, and many other quality-of-life \
    improvements missing in the default Scala REPL. \
    Note that Ammonite is deprecated upstream. For Scala scripting use the Mill \
    build tool, and most REPL features are now available in the upstream Scala \
    REPL 3.8.2 and later.
homepage            https://ammonite.io/
supported_archs     noarch
license             MIT
use_xcode           no

master_sites        https://github.com/com-lihaoyi/Ammonite/releases/download/${version}/
distname            2.13-${version}
distfiles           ${distname}
extract.suffix      ""
checksums           md5    6cb66a5930b1beb5e4cfc317c9b8a3ff\
                    sha1   2a5b6ec4f1fe1434a2f6a2bcc70b01c8fb4ba28b\
                    rmd160 385b8bc2f8c741f9fd99725cc5997ee299863603\
                    sha256 34207966e5be0aac45958635d2617a4d41dd665d44f1017280f7725b616d09ee\
                    size   69359334

use_configure       no

# Require java version
java.version        11+
# JDK port to install if required java not found
java.fallback       openjdk11

depends_run         port:scala2.13

if {$subport == $name} {
    depends_lib          port:ammonite-repl_select
    select.group         ammonite-repl
    select.file          ${filespath}/${name}

    extract {
        file mkdir ${worksrcpath}
        file copy ${distpath}/${distfiles} ${worksrcpath}/${distfiles}
    }

    set ammonite.cmd    amm

    build {
        system "(echo \"#!/usr/bin/env sh\" && cat ${worksrcpath}/${distfiles}) > ${worksrcpath}/${ammonite.cmd}"
    }

    destroot {
        set ammonitedir ${prefix}/share/${name}

        xinstall -m 755 -d ${destroot}${ammonitedir}/bin
        xinstall -m 755 ${worksrcpath}/${ammonite.cmd} ${destroot}${ammonitedir}/bin
    }
}

notes "
Ammonite is deprecated upstream (https://github.com/com-lihaoyi/Ammonite).
For Scala scripting, use the Mill build tool; most REPL features are now
available in the upstream Scala REPL 3.8.2 and later.

To use Ammonite, run:

    ${prefix}/share/${name}/bin/amm
"
