Subject: [PATCH] Attempt to fix build with macosx (ticket #24).

---
 src/video_out/video_out_macosx.m | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/src/video_out/video_out_macosx.m b/src/video_out/video_out_macosx.m
index 2b225dbb3..686e4dc5b 100644
--- src/video_out/video_out_macosx.m
+++ src/video_out/video_out_macosx.m
@@ -1,5 +1,5 @@
 /*
- * Copyright (C) 2000-2003 the xine project
+ * Copyright (C) 2000-2024 the xine project
  *
  * This file is part of xine, a free video player.
  *
@@ -350,11 +350,13 @@ static int macosx_redraw_needed(vo_driver_t *vo_driver) {
  * Class related functions.
  */
 
-static void *init_class (xine_t *xine, void *visual) {
-  macosx_class_t        *this;
-  
-  this = calloc(1, sizeof(macosx_class_t));
+static void *init_class (xine_t *xine, const void *visual) {
+  macosx_class_t *this = calloc (1, sizeof (macosx_class_t));
+
+  if (!this)
+    return NULL;
 
+  (void)visual;
   this->driver_class.open_plugin     = open_plugin;
   this->driver_class.identifier      = "MacOSX";
   this->driver_class.description     = N_("xine video output plugin for Mac OS X");
