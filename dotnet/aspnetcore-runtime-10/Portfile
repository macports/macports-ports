PortSystem          1.0

name                aspnetcore-runtime-10
version             10.0.5
revision            0
categories          dotnet
license             MIT
maintainers         @BjarneDMat {@judaew judaew} openmaintainer

description         ASP.NET Core is a cross-platform .NET framework for building modern \
                    cloud-based web applications on Windows, Mac, or Linux.

long_description    .NET is a free, cross-platform, open source developer platform \
                    for building many different types of applications. \
                    \
                    With .NET, you can use multiple languages, editors, and libraries \
                    to build for web, mobile, desktop, games, and IoT.

homepage            https://dotnet.microsoft.com/
platforms           {darwin any} {darwin >= 21}
supported_archs     x86_64 arm64

switch ${build_arch} {
    x86_64 {
        distname            aspnetcore-runtime-${version}-osx-x64
        checksums           rmd160  4c37cc19c6c75fa07f8f7e59059ab8e4b659f6b5 \
                            sha256  40ea5d0eef20b6989695b335ef62560ae9971284f61f2c416e746d16e5ef4ef3 \
                            size    48407475
    }
    arm64 {
        distname            aspnetcore-runtime-${version}-osx-arm64
        checksums           rmd160  5d0508d2ad9aee85a44de26013bea2c1fe2fb457 \
                            sha256  5abcc98712fb0c2198a249447fa9bf23f2799da181b80c2c347a6ef7c6566c93 \
                            size    45543906
    }
    default {
        known_fail yes
        pre-fetch {
            ui_error "${subport} @ ${version} only supported for architectures ${supported_archs}"
            return -code error "Unsupported architecture: ${build_arch}"
        }
    }
}

master_sites        https://builds.dotnet.microsoft.com/dotnet/aspnetcore/Runtime/${version}/

worksrcdir          ${name}-${version}
extract.mkdir       yes

use_configure       no

depends_run         port:dotnet-cli \
                    port:dotnet-runtime-10

build {}

destroot {
    set dotnet_home ${prefix}/share/dotnet
    set runtime_dir /shared/Microsoft.AspNetCore.App
    xinstall -d ${destroot}${dotnet_home}${runtime_dir}

    move ${worksrcpath}${runtime_dir}/${version} ${destroot}${dotnet_home}${runtime_dir}
}

livecheck.type      regex
livecheck.url       https://dotnet.microsoft.com/download/dotnet/10.0
livecheck.regex     "ASP.NET Core Runtime (\\d+(?:\\.\\d+)*)"
