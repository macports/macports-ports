PortSystem          1.0
PortGroup           cmake 1.1
PortGroup           github 1.0
PortGroup           legacysupport 1.1

# _strlen, _strdup
legacysupport.newest_darwin_requires_legacy 10

github.setup        hyprwm Hypr 855ef848fe0aded503b4100e734e58a3b872a91f
version             2023.08.23
revision            0
categories          x11 sysutils
license             BSD
maintainers         {@barracuda156 gmail.com:vital.had} openmaintainer
description         ${name} is a dynamic tiling window manager for Xorg
long_description    {*}${description}
checksums           rmd160  ab812e60bf01503b972aa92518ff4f269c490640 \
                    sha256  bc8ab34d215707b506d4c3d43e4d9d83b876b2d989906fbd82ad827045e7bb05 \
                    size    63927
github.tarball_from archive

depends_build-append \
                    port:pkgconfig

depends_lib-append  path:lib/pkgconfig/cairo.pc:cairo \
                    port:desktop-file-utils \
                    path:lib/pkgconfig/glib-2.0.pc:glib2 \
                    port:gtkmm3 \
                    path:lib/pkgconfig/harfbuzz.pc:harfbuzz \
                    port:xorg-libxcb \
                    port:xorg-libXinerama \
                    port:xorg-libXrandr \
                    port:xorg-xcb-util-cursor \
                    port:xorg-xcb-util-keysyms \
                    port:xorg-xcb-util-wm

compiler.cxx_standard   2017

patchfiles          0001-CMakeLists-fix-compiler.patch

# https://github.com/hyprwm/Hypr/pull/126
patchfiles-append   0002-Vector.cpp-add-required-header.patch

if {[string match *clang* ${configure.compiler}]} {
    configure.cxxflags-append \
                    -Wno-c++11-narrowing
}

destroot {
    copy ${cmake.build_dir}/${name} ${destroot}${prefix}/bin/
    set appdir ${prefix}/share/applications
    set docdir ${prefix}/share/doc/${name}
    xinstall -d ${destroot}${appdir}
    xinstall -d ${destroot}${docdir}
    xinstall -m 0644 ${worksrcpath}/example/hypr.desktop \
        ${destroot}${appdir}
    xinstall -m 0644 -W ${worksrcpath} CONTRIBUTING.md LICENSE README.md \
        ${destroot}${docdir}
    xinstall -m 0644 ${worksrcpath}/example/hypr.conf \
        ${destroot}${docdir}
}

post-activate {
    system "${prefix}/bin/update-desktop-database ${prefix}/share/applications"
}
