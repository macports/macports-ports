build.args-append   --package ${name} \
                    --package ${name}-runtime

destroot {
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/${name} \
        ${destroot}${prefix}/bin/

    xinstall -m 0644 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/lib${name}_runtime.a \
        ${destroot}${prefix}/lib/
}

notes               "Perry invokes clang when compiling TypeScript. The \
                    Xcode command line tools provide /usr/bin/clang; to use \
                    a MacPorts LLVM toolchain instead, set PERRY_LLVM_CLANG \
                    to the desired clang executable."

