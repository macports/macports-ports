+static void recordSection(const struct section *sect, uintptr_t slide,
+                          UnwindInfoSections &info) {
+  if (strncmp(sect->segname, "__TEXT", 16) != 0 || sect->size == 0)
+    return;
+#if defined(_LIBUNWIND_SUPPORT_DWARF_UNWIND)
+  if (strncmp(sect->sectname, "__eh_frame", 16) == 0) {
+    info.dwarf_section = (uintptr_t)sect->addr + slide;
+    info.dwarf_section_length = (size_t)sect->size;
+  }
+#endif
+  if (strncmp(sect->sectname, "__unwind_info", 16) == 0) {
