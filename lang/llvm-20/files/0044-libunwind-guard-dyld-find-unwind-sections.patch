+static bool checkAddrInSegment(const struct segment_command *seg,
+                               uintptr_t slide, uintptr_t targetAddr) {
+  uintptr_t begin = (uintptr_t)seg->vmaddr + slide;
+  uintptr_t end = begin + seg->vmsize;
+  return (seg->vmsize != 0) && (begin <= targetAddr) && (targetAddr < end);
