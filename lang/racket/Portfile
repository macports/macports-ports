# https://github.com/racket/racket/issues/5025
# diff -NaurdwB -I '^;;[[:space:]]*' ./racket-orig/ ./racket-new | sed -E -e 's/\.\/racket-(orig|new)/\./g' > ~/Downloads/paths-to-openssl.diff
patchfiles-append   paths-to-openssl.diff

# please remove after these commits are released
# https://github.com/racket/racket/commit/85ecfcb873092773a4897d68ddcb9bed7f941497
# https://github.com/racket/gui/commit/aea05e8b91bb78a398374f2b32f4f13a20303118#diff-7f2aa32a6df5d6cb5a9c21dd8fb9f00bd480fb38715269eeef4411676dda783a
# diff -NaurdwB -I '^;;[[:space:]]*' ./racket-orig/ ./racket-new | sed -E -e 's/\.\/racket-(orig|new)/\./g' > ~/Downloads/patch-destdir-codesign-uninit.diff
patchfiles-append   patch-destdir-codesign-uninit.diff
                   
post-patch {
    foreach rkt {libcrypto.rkt libssl.rkt} {
        reinplace "s|@@PREFIX@@|${prefix}|g" \
            ${worksrcpath}/../collects/openssl/${rkt}
    }

    # https://github.com/racket/racket/issues/5055#issuecomment-2321445579
    # collects/racket/private/so-search.rkt
    reinplace -E \
        "s|^#hash\\((.+)\\)$|#hash(\\1 (lib-search-dirs . (\"${prefix}/lib\" \"${frameworks_dir}\" #f)))|" \
        ${worksrcpath}/../etc/config.rktd

    # use MacPorts-installed libraries
    # ossp-uuid provides libuuid.16
    # jpeg-turbo provides libjpeg.8
    # gettext-runtime provides libintl.8
    # mpfr provides libmpfr.6
    # poppler provides libpoppler.136
    # libffi provides libffi.8
    foreach rkt [list \
                    "${worksrcpath}/native-libs/install.rkt" \
                    "${worksrcpath}/../share/pkgs/draw-lib/racket/draw/unsafe/cairo-lib.rkt" \
                    "${worksrcpath}/../share/pkgs/draw-lib/racket/draw/unsafe/glib.rkt" \
                    "${worksrcpath}/../share/pkgs/draw-lib/racket/draw/unsafe/jpeg.rkt" \
        ] {
        foreach re [list \
                    "s|libffi\\.6|libffi.8|g" \
                    "s|libintl\\.9|libintl.8|g" \
                    "s|libjpeg\\.9|libjpeg.8|g" \
                    "s|libmpfr\\.4|libmpfr.6|g" \
                    "s|libpoppler\\.44|libpoppler.136|g" \
                    "s|libuuid\\.1|libuuid.16|g" \
            ] {
            reinplace -q ${re} ${rkt}
        }
    }
}

worksrcdir          ${worksrcpath}/src

depends_build-append \
                    port:libtool

depends_lib-append  path:lib/libcrypto.dylib:openssl \
                    path:lib/libssl.dylib:openssl \
                    port:expat \
                    port:fontconfig \
                    port:freetype \
                    port:libffi \
                    port:libiconv \
                    port:lz4 \
                    port:ncurses \
                    port:zlib

configure.args-append \
                    --enable-curses \
                    --enable-liblz4 \
                    --enable-libz \
                    --enable-pthread

if {${configure.build_arch} in [list ppc ppc64]} {
    # Stripping may fail on PowerPC:
    # https://github.com/racket/racket/issues/5021
    configure.args-append \
                    --disable-strip \
                    --enable-bigendian
}

variant x11 \
    description {Use X11 GUI.} {}

if { [variant_isset "x11"] } {
    PortGroup       active_variants 1.1

    depends_lib-append \
                    port:gdk-pixbuf2 \
                    port:gtk2

    require_active_variants gtk2 x11
} else {
    depends_build-append \
                    port:cctools \
                    port:file \
                    port:grep \
                    port:gsed \
                    path:bin/openssl:openssl

    # https://github.com/racket/libs/tree/master/draw-x86_64-macosx-3/racket/draw
    # https://github.com/racket/libs/tree/master/gui-x86_64-macosx/racket/gui
    # https://github.com/racket/libs/tree/master/math-x86_64-macosx/math
    # https://github.com/racket/libs/tree/master/racket-x86_64-macosx-4/racket
    depends_lib-append \
                    port:atk \
                    port:cairo \
                    port:fribidi \
                    port:gettext-runtime \
                    port:glib2 \
                    port:harfbuzz \
                    port:libedit \
                    port:libjpeg-turbo \
                    port:libpixman \
                    port:libpng \
                    port:MMTabBarView \
                    port:mpfr \
                    port:ossp-uuid \
                    port:pango \
                    port:poppler

    configure.args-append \
                    --disable-origtree \
                    --enable-macprefix \
                    --guibindir=${applications_dir}

    # please add at next upgrade
    #                 --enable-nonatipkg

    # please remove at next upgrade
    # https://github.com/racket/racket/issues/5292#issuecomment-3049547317
    patchfiles-append \
                    patch-objc_rkt.diff \
                    patch-guibindir.diff
    
    # please remove at next upgrade
    post-configure {
        reinplace -E \
            "s|^\[\[:space:]]*CONFIGURE_RACKET_SO_COMPILE\[\[:space:]]*=\[\[:space:]]*$|CONFIGURE_RACKET_SO_COMPILE = PLT_CS_SLSP_SUFFIX=-nonatipkg|" \
            ${worksrcpath}/cs/c/Makefile
        reinplace -E \
            "s|^\[\[:space:]]*PLT_CS_SLSP_SUFFIX\[\[:space:]]*=\[\[:space:]]*$|PLT_CS_SLSP_SUFFIX = -nonatipkg|" \
            ${worksrcpath}/cs/c/Makefile
    }
    
    post-destroot {
        set Name    [string totitle ${name}]
        set Name_fw ${Name}.framework/Versions/${version}_CS/${Name}

        # framework
        xinstall -d ${destroot}${frameworks_dir}
        move        ${destroot}${prefix}/lib/${name}/${Name}.framework \
                    ${destroot}${frameworks_dir}
        system -W ${destroot}${frameworks_dir} \
                    "install_name_tool -change '${Name_fw}' '@rpath/${Name_fw}' '${Name_fw}'"

        # GRacket.app
        system -W   ${destroot}${prefix}/lib/${name} \
                    "install_name_tool -change '${prefix}/lib/${name}/${Name_fw}' '${frameworks_dir}/${Name_fw}' GRacket.app/Contents/MacOS/GRacket"

        # binaries
        foreach binfile {mzscheme racket} {
            system -W ${destroot}${prefix}/bin \
                    "install_name_tool -change '${prefix}/lib/${name}/${Name_fw}' '${frameworks_dir}/${Name_fw}' '${binfile}'"
            if {${configure.build_arch} eq {arm64}} {
                system -W ${destroot}${prefix}/bin \
                    "codesign -f -s - '${binfile}'"
            }
        }

        # apps
        foreach app_name [list \
                    DrRacket \
                    "PLT Games" \
                    "Racket Documentation" \
                    Slideshow \
            ] {
            system -W ${destroot}${applications_dir} \
                "install_name_tool -change '${prefix}/lib/${name}/${Name_fw}' '${frameworks_dir}/${Name_fw}' '${app_name}.app/Contents/MacOS/${app_name}'"
            if {${configure.build_arch} eq {arm64}} {
                system "codesign -f -s - '${destroot}${applications_dir}/${app_name}.app/Contents/MacOS/${app_name}'"
            }
        }
    }
}

proc slash_hack {binfile build_idir replacedir} {
    global configure.build_arch
    xinstall -m 0755 \
                    ${binfile} \
                    ${binfile}.slash_hack
    if {![string trim [exec sh -c \
        "if LC_ALL='C' ggrep -F -a -c -q -e [shellescape ${build_idir}] \
            [shellescape ${binfile}.slash_hack] 2>/dev/null; \
                then echo '1'; else echo '0'; fi"]]} {
        delete ${binfile}.slash_hack
        return
    }
    set extra_slashes \
        [expr {[string length ${build_idir}] - [string length ${replacedir}]}]
    if {${extra_slashes} >= 0} {
        set slash_hack \
                    [string repeat / ${extra_slashes}]
        set installsubdir_slash_hack ${slash_hack}${replacedir}
        set build_idir_esc \
                    [strsed ${build_idir} {g|/|\\/|}]
        set installsubdir_slash_hack_esc \
                    [strsed ${installsubdir_slash_hack} {g|/|\\/|}]
        system      "gsed -i -e\
                        's/${build_idir_esc}/${installsubdir_slash_hack_esc}/g'\
                        '${binfile}.slash_hack'"
    } else {
        delete ${binfile}.slash_hack
        return
    }
    if {([file size ${binfile}.slash_hack] == [file size ${binfile}])
        && ([exec openssl dgst -ripemd160 ${binfile}.slash_hack] \
            ne [exec openssl dgst -ripemd160 ${binfile}])} {
        # gsed created a different file of the same size
        delete ${binfile}
        xinstall -m 0755 \
                    ${binfile}.slash_hack \
                    ${binfile}
        if {${configure.build_arch} eq {arm64}} {
            system "codesign -f -s - '${binfile}'"
        }
    }
    delete ${binfile}.slash_hack
}


