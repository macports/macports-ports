}

if {[vercmp ${xcodeversion} ${requiredXcodeVersion}] < 0} {
    known_fail      yes
    pre-fetch {
        ui_error "${name} @${version} requires Xcode ${requiredXcodeVersion} or later."
        return -code error "incompatible Xcode version"
    }
}

description         Formatting technology for Swift source code
long_description    swift-format provides the formatting technology for SourceKit-LSP and the building blocks for doing code formatting transformations.

use_configure       no
use_xcode           yes

build.type          xcode
build.cmd           swift
build.args          --configuration release -Xswiftc -Onone --disable-sandbox
build.target        build

destroot {
    xinstall -m 755 ${worksrcpath}/.build/release/swift-format ${destroot}${prefix}/bin/
}
