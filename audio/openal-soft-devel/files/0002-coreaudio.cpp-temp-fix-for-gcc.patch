 }
 
 void CoreAudioCapture::stop()
 {
     OSStatus err{AudioOutputUnitStop(mAudioUnit)};
     if(err != noErr)
+#ifdef __clang__
         ERR("AudioOutputUnitStop failed: '{}' ({})", FourCCPrinter{err}.c_str(), err);
+#else
+        ERR("AudioOutputUnitStop failed\n");
+#endif
 }
 
