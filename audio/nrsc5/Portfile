compiler.c_standard 2011

configure.args-append \
                    -DUSE_FAAD2=ON

if {${configure.build_arch} ni [list ppc ppc64]} {
    configure.args-append \
                    -DUSE_NEON=ON \
                    -DUSE_SSE=ON
}

