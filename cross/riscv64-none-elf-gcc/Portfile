                    bin:makeinfo:texinfo

configure.args-append \
                    --disable-newlib-supplied-syscalls \
                    --with-arch=rv64gc \
                    --with-abi=lp64d \
                    "--with-multilib-generator=rv64gc-lp64d--\\;rv64imac-lp64--\\;rv64ima-lp64--"
