# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           github 1.0

github.setup        xykong flux-markdown 1.25.310 v
github.tarball_from releases

categories          aqua sysutils
platforms           {darwin >= 21}
supported_archs     x86_64 arm64
license             GPL-3
maintainers         {@xykong gmail.com:xy.kong} openmaintainer

description         Markdown previews in Finder QuickLook with diagrams and math
long_description    FluxMarkdown is a macOS QuickLook extension for Markdown files. \
                    It renders Mermaid diagrams, KaTeX math, GitHub Flavored Markdown \
                    (including Alerts), syntax-highlighted code blocks, Vega/Vega-Lite \
                    charts, and Graphviz DOT diagrams. Features include an interactive \
                    table of contents, YAML frontmatter display, PDF and HTML export, \
                    zoom, scroll position memory, and light/dark/system themes.

distname            FluxMarkdown

checksums           rmd160  9bd4876581f153ce9aa0255945e80177f5d7d00b \
                    sha256  27b1c1c60085274ecd1107be0f6c4645d8a9864073f5f3bf4b2b4014fccb1882 \
                    size    10700086

use_dmg             yes
use_configure       no

build {}

destroot {
    copy ${worksrcpath}/FluxMarkdown.app ${destroot}${applications_dir}
}

post-activate {
    system "/usr/bin/xattr -cr ${applications_dir}/FluxMarkdown.app"
    system "/usr/bin/pluginkit -a ${applications_dir}/FluxMarkdown.app/Contents/PlugIns/MarkdownPreview.appex"
    system "/usr/bin/qlmanage -r"
}
