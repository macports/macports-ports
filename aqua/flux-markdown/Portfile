# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           github 1.0

github.setup        xykong flux-markdown 1.31.402 v
github.tarball_from releases

categories          aqua sysutils
platforms           {darwin >= 21}
supported_archs     x86_64 arm64
license             GPL-3
maintainers         {@xykong gmail.com:xy.kong} openmaintainer

description         Markdown previews in Finder QuickLook with diagrams and math
long_description    FluxMarkdown is a macOS QuickLook extension for Markdown files. \
                    It renders Mermaid diagrams, KaTeX math, GitHub Flavored Markdown \
                    (including Alerts), syntax-highlighted code blocks, Vega/Vega-Lite \
                    charts, and Graphviz DOT diagrams. Features include an interactive \
                    table of contents, YAML frontmatter display, PDF and HTML export, \
                    zoom, scroll position memory, and light/dark/system themes.

# MacPorts-specific source tarball: pre-generated .xcodeproj, pre-built
# web-renderer/dist, and Sparkle removed (MacPorts manages updates).
# Generated by scripts/create_macports_tarball.sh during the release process.
distname            FluxMarkdown-1.31.402-macports-source
extract.suffix      .tar.gz

checksums           rmd160  4026d26f2eb88c890e039739ec6c172a987e47f1 \
                    sha256  b9a9851dec435361a2ceeb5810c29f2af6f7e265a333be449d02bdecb2fe4b90 \
                    size    9830669

use_configure       no
use_xcode           yes

build {
    system -W ${worksrcpath} \
        "xcodebuild \
            -project FluxMarkdown.xcodeproj \
            -scheme Markdown \
            -configuration Release \
            -derivedDataPath ${workpath}/DerivedData \
            CODE_SIGN_IDENTITY='' \
            CODE_SIGNING_REQUIRED=NO \
            CODE_SIGN_ENTITLEMENTS='' \
            AD_HOC_CODE_SIGNING_ALLOWED=YES \
            MARKETING_VERSION=${version} \
            -quiet"
}

destroot {
    copy ${workpath}/DerivedData/Build/Products/Release/FluxMarkdown.app \
         ${destroot}${applications_dir}
}

post-activate {
    system "/usr/bin/xattr -cr ${applications_dir}/FluxMarkdown.app"
    system "/usr/bin/pluginkit -a \
        ${applications_dir}/FluxMarkdown.app/Contents/PlugIns/MarkdownPreview.appex"
    system "/usr/bin/qlmanage -r"
}
