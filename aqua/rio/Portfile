post-patch {
    system -W ${worksrcpath}/misc/osx/${appname}.app/Contents \
        "/usr/libexec/PlistBuddy -c \"Set :CFBundleShortVersionString ${version}\" Info.plist"
}

destroot {
    copy ${worksrcpath}/misc/osx/${appname}.app ${destroot}${applications_dir}
    file mkdir ${destroot}${applications_dir}/${appname}.app/Contents/MacOS
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/${name} \
        ${destroot}${applications_dir}/${appname}.app/Contents/MacOS/
    system -W ${destroot}${applications_dir} "/usr/bin/codesign --sign - ${appname}.app"
    ln -s ${applications_dir}/${appname}.app/Contents/MacOS/${name} ${destroot}${prefix}/bin/
}

