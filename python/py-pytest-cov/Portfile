    post-destroot {
        set docdir ${prefix}/share/doc/${subport}
        xinstall -d ${destroot}${docdir}
        xinstall -m 0644 -W ${worksrcpath} LICENSE CONTRIBUTING.rst \
            AUTHORS.rst CHANGELOG.rst README.rst ${destroot}${docdir}
    }
