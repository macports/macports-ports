    depends_build-append \
                    port:py${python.version}-setuptools_scm

    test.run        yes

    post-destroot {
        set docdir ${prefix}/share/doc/${subport}
        xinstall -d ${destroot}${docdir}
        xinstall -m 0644 -W ${worksrcpath} README.rst \
            LICENSE ${destroot}${docdir}
    }
