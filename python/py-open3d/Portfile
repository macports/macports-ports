# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           active_variants 1.1
PortGroup           boost 1.0
PortGroup           cmake  1.1
PortGroup           github 1.0
PortGroup           openssl 1.0
PortGroup           python 1.0

github.setup        isl-org Open3D 0.19.0 v
name                py-[string tolower ${github.project}]
categories-append   graphics science
license             MIT
maintainers         nomaintainer
supported_archs     arm64 x86_64
fetch.type          git

description         A Modern Library for 3D Data Processing.
long_description    Open3D is an open-source library that supports rapid \
                    development of software that deals with 3D data. The \
                    Open3D frontend exposes a set of carefully selected \
                    data structures and algorithms in both C++ and Python. \
                    The backend is highly optimized and is set up for \
                    parallelization.

homepage            https://www.open3d.org/

python.versions     313 314

# subport open3d has C++ libraries
subport ${python.rootname} {}

# Development notes:
#   * Upstream requires a git clone to build
#   * Upstream build downloads 3d party code not specified in USE_SYSTEM_*
#      o Latest embree + MacPorts tbb observed to be incompatible
#        (missing symbol in libtbb)
#      o Latest embree + MacPorts onetbb observed to be incompatible
#        (sugmentation fault with onetbb)

set docdir          ${prefix}/share/doc/${subport}

if {${name} ne ${subport}} {
    compiler.cxx_standard 2017

    boost.version   1.88

    depends_build-append \
                    path:bin/ccache:ccache \

    depends_lib-append \
                    port:assimp \
                    port:cppzmq \
                    port:glew \
                    port:glfw \
                    port:gtest \
                    port:jsoncpp \
                    port:libfmt12 \
                    path:include/turbojpeg.h:libjpeg-turbo \
                    port:libomp \
                    port:libpng \
                    port:libproj4 \
                    port:minizip \
                    port:msgpack-cpp \
                    port:nanoflann \
                    path:lib/libopenblas.dylib:OpenBLAS \
                    port:openssl3 \
                    port:qhull \
                    port:tinyobjloader \
                    port:vtk \
                    port:zlib \
                    port:zmq

    cmake.module_path-append \
                    ${prefix}/lib/libfmt12/cmake

    cmake.build_type    Release

    cmake.build_dir ${worksrcpath}/build
    post-patch {
        xinstall -d ${cmake.build_dir}
    }

    # Fix https://github.com/isl-org/Open3D/issues/7390
    # diff -NaurdwB ./py-open3d-orig/3rdparty/possionrecon/possionrecon.cmake ./py-open3d-new/3rdparty/possionrecon/possionrecon.cmake | sed -E -e 's/\.\/py-open3d-(orig|new)/\./g' | sed -E -e 's|/opt/local|@@PREFIX@@|g' > ~/Downloads/patch-possionrecon_cmake.diff
    patchfiles-append   patch-possionrecon_cmake.diff

    # symbol open3d_core_cuda_device_count, function defined to return 0
    # diff -NaurdwB ./py-open3d-orig/cpp/pybind/CMakeLists.txt ./py-open3d-new/cpp/pybind/CMakeLists.txt | sed -E -e 's/\.\/py-open3d-(orig|new)/\./g' | sed -E -e 's|/opt/local|@@PREFIX@@|g' > ~/Downloads/patch-pybind_CMakeLists_txt.diff
    patchfiles-append   patch-pybind_CMakeLists_txt.diff

    # ccache configuration
    configure.ccache    yes
    set ccache_dir      ${workpath}/.ccache
    post-patch {
        xinstall -d     ${ccache_dir}
    }

    if {[tbool configure.ccache]} {
        configure.env-append   CCACHE_DIR=${ccache_dir} USE_CCACHE=ON
        build.env-append       CCACHE_DIR=${ccache_dir} USE_CCACHE=ON
        destroot.env-append    CCACHE_DIR=${ccache_dir} USE_CCACHE=ON
    }

    compiler.cpath-append \
                    ${prefix}/include/libomp \
                    ${prefix}/include/minizip \
                    ${prefix}/include/openblas

    compiler.library_path-append \
                    ${prefix}/lib/libomp

    configure.cflags-append \
                    -Wdeprecated-declarations \
                    -Wno-deprecated-declarations \
                    -Wno-sign-compare

    # these flags are add in DCMAKE_CXX_FLAGS to avoid downstream's cmake system's `-Wall -Wextra -Werror`
    configure.cxxflags-append \
                    -Wdeprecated-declarations \
                    -Wno-deprecated-declarations \
                    -Wno-sign-compare

    configure.cppflags-append \
                    -I${prefix}/include/libomp

    configure.ldflags-append \
                    -lcrypto

    # https://www.open3d.org/docs/release/compilation.html
    use_configure   yes

    pre-configure { 
        xinstall -d ${workpath}/bin
        ln -s       ${python.bin} \
                    ${workpath}/bin/python3
        configure.env-append \
                    PATH=${workpath}/bin:$::env(PATH)
    }

    configure.args \
                    -DBoost_INCLUDE_DIR=[boost::include_dir] \
                    -DBUILD_CUDA_MODULE=OFF \
                    -DBUILD_ISPC_MODULE=OFF \
                    -DBUILD_JUPYTER_EXTENSION=OFF \
                    -DBUILD_SHARED_LIBS=ON \
                    -DBUILD_TENSORFLOW_OPS=OFF \
                    -DBUILD_WEBRTC=OFF \
                    "-DCMAKE_CXX_FLAGS=\"-DEIGEN_AVOID_STL_ARRAY \
                        -DEIGEN_DONT_VECTORIZE \
                        -Wdeprecated-declarations \
                        -Wno-deprecated-declarations \
                        -Wno-sign-compare\"" \
                    -DGLIBCXX_USE_CXX11_ABI=OFF \
                    -DUSE_BLAS=ON \
                    -DUSE_SYSTEM_BLAS=ON \
                    -DUSE_SYSTEM_ASSIMP=ON \
                    -DUSE_SYSTEM_CURL=ON \
                    -DUSE_SYSTEM_EIGEN3=ON \
                    -DUSE_SYSTEM_FMT=ON \
                    -DUSE_SYSTEM_GLEW=ON \
                    -DUSE_SYSTEM_GLFW=ON \
                    -DUSE_SYSTEM_GOOGLETEST=ON \
                    -DUSE_SYSTEM_JPEG=ON \
                    -DUSE_SYSTEM_JSONCPP=ON \
                    -DUSE_SYSTEM_MSGPACK=ON \
                    -DUSE_SYSTEM_NANOFLANN=ON \
                    -DUSE_SYSTEM_OPENSSL=ON \
                    -DUSE_SYSTEM_PNG=ON \
                    -DUSE_SYSTEM_QHULLCPP=ON \
                    -DUSE_SYSTEM_TINYOBJLOADER=ON \
                    -DUSE_SYSTEM_VTK=ON \
                    -DUSE_SYSTEM_ZEROMQ=ON \
                    -DWITH_OPENMP=ON

    if {"-DUSE_SYSTEM_EIGEN3=ON" in ${configure.args}} {
        # diff -NaurdwB ./py-open3d-orig/cpp/open3d/ml/impl/misc/VoxelPooling.h ./py-open3d-new/cpp/open3d/ml/impl/misc/VoxelPooling.h | sed -E -e 's/\.\/py-open3d-(orig|new)/\./g' | sed -E -e 's|/opt/local|@@PREFIX@@|g' > ~/Downloads/patch-VoxelPooling_h.diff
        patchfiles-append   patch-VoxelPooling_h.diff

        depends_lib-append \
                    port:eigen3

        compiler.cpath-prepend \
                    ${prefix}/include/eigen3 \
    }

    configure.post_args ..

    # required for cmake
    build.cmd       [portbuild::build_getmaketype]
    build.target

    pre-build {
        build.pre_args  [portbuild::build_getargs]
        build.args
        build.post_args VERBOSE=ON
    }

    if {[string match "py*-open3d" ${subport}]} {
        description Python bindings for {*}[lrange ${description} 1 end]

        require_active_variants boost[boost::version_nodot] python${python.version}

        depends_build-append \
                    port:py${python.version}-pip \
                    port:py${python.version}-setuptools \
                    port:py${python.version}-pybind11 \
                    port:py${python.version}-wheel

        depends_lib-append \
                    port:py${python.version}-configargparse \
                    port:py${python.version}-dash \
                    port:py${python.version}-flask \
                    port:py${python.version}-ipywidgets \
                    port:py${python.version}-jupyter_packaging \
                    port:py${python.version}-jupyterlab \
                    port:py${python.version}-nbformat \
                    port:py${python.version}-numpy \
                    port:py${python.version}-pygments \
                    port:py${python.version}-pytorch \
                    port:py${python.version}-werkzeug \
                    port:py${python.version}-yapf

        depends_run-append \
                    port:py${python.version}-addict

        depends_test-append \
                    port:py${python.version}-certifi \
                    port:py${python.version}-oauthlib \
                    port:py${python.version}-pytest \
                    port:py${python.version}-scipy
    
        set open3d_ml_distname  [string map "${github.project} ${github.project}-ML" ${distname}]
        set open3d_ml_root      ${worksrcpath}/${open3d_ml_distname}

        post-extract {
            # build looks for branch `main`; checkout the current version of Open3D-ML
            system -W ${worksrcpath} \
                    "git clone --depth 1 --branch main ${github.homepage}-ML.git ${open3d_ml_root} \
                        && git checkout ${git.branch}"
        }

        configure.args-append \
                    -DBUILD_PYTHON_MODULE=ON \
                    -DBUILD_PYTORCH_OPS=ON \
                    -DBUNDLE_OPEN3D_ML=ON \
                    "-DOPEN3D_ML_ROOT=${open3d_ml_root}" \
                    -DPYTHON_EXECUTABLE=${python.bin} \
                    -DUSE_SYSTEM_PYBIND11=ON

        post-build {
            if {"-DUSE_SYSTEM_TBB=ON" ni ${configure.args}} {
                # Open3D's Python install self-loads; must copy built dylib's
                set appleclang_dir [lindex \
                    [glob -types d "${cmake.build_dir}/appleclang*_release"] 0]
                # copy the actual shared library
                set tbb_dylib ""
                foreach dyl [glob -types f "${appleclang_dir}/libtbb.*dylib"] {
                    if {[file type ${dyl}] eq "file"} {
                        set tbb_dylib [file tail ${dyl}]
                        copy ${dyl} ${cmake.build_dir}/lib/Release/cpu
                        break
                    }
                }
                # re-create the shared links
                foreach dyll [glob -types f "${appleclang_dir}/libtbb.*dylib"] {
                    if {[file type ${dyll}] eq "link"} {
                        ln -s ${tbb_dylib} \
                            ${cmake.build_dir}/lib/Release/cpu/[file tail ${dyll}]
                    }
                }
            }

            # make pip-package
            system -W ${cmake.build_dir} [join [list \
                ${build.cmd} {*}${build.jobs_arg} {*}${build.pre_args} \
                    pip-package {*}${build.post_args}] " "]
        }

        pre-destroot {
            set open3d_wheel [lindex \
                [glob -types f \
                    "${cmake.build_dir}/lib/python_package/pip_package/open3d-${version}*.whl"] 0]

            destroot.post_args \
                ${open3d_wheel}
        }

        destroot.cmd           pip-${python.branch}
        destroot.target        install
        destroot.args --prefix ${python.prefix} \
            --ignore-installed \
            --no-cache-dir     \
            --no-dependencies  \
            --root ${destroot}

        post-destroot {
            if {"-DUSE_SYSTEM_TBB=ON" ni ${configure.args}} {
                xinstall -d ${destroot}${python.pkgd}/${python.rootname}/lib
                foreach dyl [glob -nocomplain -types f "${destroot}${python.pkgd}/${python.rootname}/libtbb.*dylib"] {
                    if {[file type ${dyl}] eq "file"} {
                        move ${dyl} ${destroot}${python.pkgd}/${python.rootname}/lib 
                    }
                }
            }

            xinstall -m 0644 -W ${filespath} o3d_mermaid_unicorn_example.py \
                ${destroot}${docdir}
        }

        test.cmd    py.test-${python.branch}
        test.run    yes

        notes-append \
            "Example script:" \
            "python${python.branch} ${docdir}/o3d_mermaid_unicorn_example.py"
    } elseif {${subport} eq "open3d"} {
        python.version  [python_get_default_version]

        pre-destroot {
            destroot.cmd        cmake
            destroot.pre_args   --build . --config ${cmake.build_type}
            destroot.args       --target install
            destroot.destdir    DESTDIR=${destroot}
            destroot.dir        ${cmake.build_dir}
        }

        post-destroot {
            # avoid port onetbb conflict
            delete ${destroot}${prefix}/lib/libtbb.dylib
        }
    }

    post-destroot {
        xinstall -d ${destroot}${docdir}
        xinstall -m 0644 -W ${worksrcpath} LICENSE README.md \
            ${destroot}${docdir}
    }
}
