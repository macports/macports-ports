if {${name} ne ${subport}} {
    depends_run-append  port:pkgconfig

    post-destroot {
        set DOCDIR ${destroot}${prefix}/share/doc/${subport}
        xinstall -d ${DOCDIR}
        xinstall -m 0644 -W ${worksrcpath} LICENSE README.rst \
            ${DOCDIR}
    }
}
