PortSystem          1.0
PortGroup           python 1.0
PortGroup           openssl 1.0

name                py-awscrt
# This is only used by awscli2. Bump when Amazon bumps
# their pinned version in awscli2's setup.cfg.
version             0.32.1
revision            0

categories-append   devel
maintainers         {gmail.com:davidgilman1 @dgilman} openmaintainer
license             Apache-2

description         A common runtime for AWS Python projects
long_description    {*}${description}

homepage            https://aws.amazon.com/cli/

checksums           rmd160  4e9ec2e5d2b065db9a46fb4bb5c6a56bfdfa5d2f \
                    sha256  1faccfaf365c7ae8975307e42edec44eb3ae3feba2805aff2979ba8474b6bb4f \
                    size    36852472

python.versions     310 311 312 313 314

if {${name} ne ${subport}} {
    if {${os.platform} eq "darwin" && ${os.major} <= 18} {
        known_fail      yes
        pre-fetch {
            ui_error "${name} @${version} requires macOS 10.15 or later."
            return -code error "incompatible macOS version"
        }
    }

    depends_build-append \
                        path:bin/cmake:cmake

    depends_lib-append  port:py${python.version}-setuptools

    build.env-append    AWS_CRT_BUILD_USE_SYSTEM_LIBCRYPTO=1
}
