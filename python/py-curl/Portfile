    if {${python.pep517}} {
        build.args      "--config-setting='--curl-config=${prefix}/bin/curl-config'"
    } else {
        build.args      --curl-config=${prefix}/bin/curl-config
        destroot.args   {*}${build.args}
    }

    livecheck.type  none
