# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim: fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           python 1.0

name                py-pyside6
version             6.8.2.1
revision            0
categories-append   devel aqua

maintainers         nomaintainer
license             LGPL
supported_archs     arm64 x86_64

python.versions     39 310 311 312 313
python.pep517       no

description         Python bindings for the Qt cross-platform application and UI framework
long_description    PySide6 is the official Python module from the Qt for Python project, \
                    which provides access to the complete Qt 6.0+ framework.
homepage            https://pyside.org/

checksums           rmd160  5138668de50f7637885070a06e9e8e1e9ec53763 \
                    sha256  13f7a00b360a5869084fcc085c48ba236915a200bb5a13c1548ed8ab7a8b606b \
                    size    16609240

master_sites        https://download.qt.io/official_releases/QtForPython/pyside6/PySide6-${version}-src
# distname          pyside-setup-everywhere-src-${version}
use_xz              yes

# ------------------------
# The extracted source directory has a wrong version number.
# Temporary fix. Check if this is still needed with the next version.
distname            pyside-setup-everywhere-src-6.8.2
distfiles           pyside-setup-everywhere-src-${version}.tar.xz
# ------------------------

set clang_versions  {18 19 20}
universal_variant   no


if {${name} ne ${subport}} {
    PortGroup       qt6 1.0

    depends_lib-append \
        port:py${python.version}-numpy

    depends_build-append \
        path:bin/cmake:cmake \
        path:bin/ninja:ninja \
        port:py${python.version}-packaging \
        port:py${python.version}-setuptools

    # -------------------------
    # Clang variants
    foreach clang_version ${clang_versions} {
        lappend clang_variants clang${clang_version}
    }
    foreach clang_version ${clang_versions} {
        set clang_variant clang${clang_version}
        variant ${clang_variant} conflicts {*}[ldelete ${clang_variants} ${clang_variant}] description "Build with ${clang_variant}" {
            depends_build-append    port:clang-${clang_version}
            build.env-append        LLVM_INSTALL_DIR=${prefix}/libexec/llvm-${clang_version}
        }
    }
    default_variants-append +[lindex $clang_variants 0] # clang-18 is used for qt6 installation
    # -------------------------

    build.args-append \
        --qtpaths=${prefix}/libexec/qt6/bin/qtpaths6 \
        --cmake=${prefix}/bin/cmake \
        --parallel=${build.jobs}

    if {${configure.sdkroot} != ""} {
        build.args-append \
            --macos-sysroot=${configure.sdkroot}
    }

    destroot.args-append \
        --qtpaths=${prefix}/libexec/qt6/bin/qtpaths6 \
        --cmake=${prefix}/bin/cmake \
        --skip-cmake \
        --reuse-build
} else {
    livecheck.type      regex
    livecheck.url       https://download.qt.io/official_releases/QtForPython/pyside6/
    livecheck.regex     (\\d+(\\.\\d+)+)
}
