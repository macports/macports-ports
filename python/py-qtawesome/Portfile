if {${name} ne ${subport}} {
    depends_lib-append \
                    port:py${python.version}-qtpy

    depends_test-append \
                    port:py${python.version}-pytest-qt

    test.run        yes

    post-destroot {
        set docdir ${prefix}/share/doc/${subport}
        xinstall -d ${destroot}${docdir}
        xinstall -m 0644 -W ${worksrcpath} LICENSE.txt CHANGELOG.md \
           README.md  ${destroot}${docdir}
    }
}
