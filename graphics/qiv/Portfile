PortSystem          1.0

name                qiv
version             3.0.2
categories          graphics
license             GPL-2
maintainers         {lloyd.io:me @lloyd}

description         A very small and pretty fast gdk/Imlib image viewer

long_description    A very small and pretty fast gdk/Imlib image viewer \
                    for X.

homepage            http://spiegl.de/qiv/
master_sites        https://codeberg.org/ciberandy/qiv/releases/download/v${version}/

checksums           rmd160  db86d30c66a6e4ece778e3418b7591221d6e7253 \
                    sha256  0a068f0171e0bf77f066283af83c3d54fb5c1802d0f4a884d156cebe0b2c7e75 \
                    size    143688

depends_build       port:pkgconfig

depends_lib         path:lib/pkgconfig/gtk+-3.0.pc:gtk3 \
                    port:lcms2 \
                    port:libexif \
                    port:libmagic

patchfiles          patch-Makefile.diff

post-patch {
    reinplace "s|@PREFIX@|${prefix}|" ${worksrcpath}/Makefile
}

use_configure       no

variant universal {}

build.args          CC="${configure.cc} [get_canonical_archflags cc]"

notes "
Install port webp-pixbuf-loader if you need qiv (and GDK Pixbuf) to
display WEBP image files.
"

livecheck.type      regex
livecheck.url       https://codeberg.org/ciberandy/qiv/releases
livecheck.regex     ${name}/archive/v(\\d+(?:\\.\\d+)*)${extract.suffix}
