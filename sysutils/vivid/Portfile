destroot {
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/${name} \
        ${destroot}${prefix}/bin/

    xinstall -d ${destroot}${prefix}/share/${name}
    foreach appdir {config themes} {
        copy ${worksrcpath}/${appdir} ${destroot}${prefix}/share/${name}/
    }
}

