go.setup            github.com/JanDeDobbeleer/oh-my-posh 29.12.0 v
go.offline_build    no
revision            0

homepage            https://ohmyposh.dev

description         A prompt theme engine for any shell.
long_description    {*}${description}

categories          sysutils shells
installs_libs       no
license             GPL-3
maintainers         {gmail.com:herby.gillot @herbygillot} \
                    {duck.com:ihj3s1wy @PinoTucana} \
                    openmaintainer

checksums           rmd160  5863321a9e6cdebbe77c3512fdb1d827e7ca1909 \
                    sha256  9cb8cf3b69ce303c3d956409d028fb171642fecfd50655562cb9df97d038896d \
                    size    7070866

build.dir           ${worksrcpath}/src

build.pre_args-append \
    -ldflags \"-X github.com/jandedobbeleer/oh-my-posh/src/build.Version=${version} \
    -X github.com/jandedobbeleer/oh-my-posh/src/build.Date="2026-01-09"\" -o ${name}

set omp_share_path  ${prefix}/share/${name}

destroot {
    xinstall -m 0755 ${worksrcpath}/src/${name} ${destroot}${prefix}/bin/

    xinstall -d ${destroot}${omp_share_path}
    file copy ${worksrcpath}/themes ${destroot}${omp_share_path}/
}

notes "
  Themes for ${name} can be found in:

    ${omp_share_path}/themes
"
