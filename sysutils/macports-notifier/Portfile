post-patch {
    reinplace -q -W ${worksrcpath} "s|/opt/local|${prefix}|g" \
            PNDefines.h \
            net.sourceforge.portsnotifier.plist \
            PNPortWrapper.m \
            PortsHelper.c

    reinplace -q -W ${worksrcpath} "s|/var/log/portsnotifier.log|${prefix}/var/log/portsnotifier.log|g" \
            net.sourceforge.portsnotifier.plist \
            PortsHelper.c
}

xcode.target            PortsNotifier
