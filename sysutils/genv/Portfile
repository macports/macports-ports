# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           golang 1.0

go.setup            github.com/ks1686/genv 2.1.0 v
go.offline_build    no
revision            0

description         Track, sync, and reproduce your software environment

long_description    genv is a command-line tool to track, sync, and reproduce \
                    your software environment across Linux, macOS, and WSL2. \
                    It manages packages, environment variables, shell aliases, \
                    and services from a single declarative genv.json file.

homepage            https://github.com/ks1686/genv
categories          sysutils
installs_libs       no
license             MIT
maintainers         {github.com:ks1686 @ks1686} openmaintainer

checksums           rmd160  eca8fccf99acda94c813c24dece201bf1a6c4820 \
                    sha256  f6ae037e39c409a4818cb18d4c02c0061a477fbde72875450a577e3b62179bcb \
                    size    139932

build.env-append    CGO_ENABLED=0
build.args          -o ${worksrcpath}/genv \
                    -ldflags "-s -w -X main.version=${version}"

destroot {
    xinstall -m 0755 ${worksrcpath}/genv ${destroot}${prefix}/bin/genv

    xinstall -d ${destroot}${prefix}/share/bash-completion/completions
    xinstall -m 0644 ${worksrcpath}/completions/genv.bash \
        ${destroot}${prefix}/share/bash-completion/completions/genv

    xinstall -d ${destroot}${prefix}/share/zsh/site-functions
    xinstall -m 0644 ${worksrcpath}/completions/genv.zsh \
        ${destroot}${prefix}/share/zsh/site-functions/_genv

    xinstall -d ${destroot}${prefix}/share/fish/vendor_completions.d
    xinstall -m 0644 ${worksrcpath}/completions/genv.fish \
        ${destroot}${prefix}/share/fish/vendor_completions.d/genv.fish
}
