# Wheels: do not try to extract
extract.only

# No configure phase
use_configure       no

depends_build       port:py${py_ver_nodot}-pip

set az_libdir       ${prefix}/share/azure-cli
set az_stagedir     ${workpath}/stage

# Install the bundled wheels into a staging directory during the build
# phase, so we don't have to run pip as root during destroot.
# We pass --no-compile because we run compileall after with the correct
# path for the final install location.
build {
    file mkdir ${az_stagedir}
    set wheels [glob ${distpath}/*.whl]
    system "${prefix}/bin/python${py_ver} -m pip install \
        --no-deps --no-index --no-build-isolation --no-compile \
        --target=${az_stagedir} \
        [join $wheels { }]"

    # Byte-compile the staged Python files. The -s/-p options rewrite
    # the embedded path to point to the final install location.
    system "${prefix}/bin/python${py_ver} -m compileall \
        -j 0 -q \
        --invalidation-mode=checked-hash \
        -s ${az_stagedir} -p ${az_libdir} \
        ${az_stagedir}"

    # Remove the per-wheel bin/ scripts that pip writes; we'll install our own.
    file delete -force ${az_stagedir}/bin
}

destroot {
    xinstall -d ${destroot}${az_libdir}
    copy {*}[glob -directory ${az_stagedir} *] ${destroot}${az_libdir}

    # Install az wrapper that runs the bundled azure.cli with MacPorts python.
    xinstall -d ${destroot}${prefix}/bin
    set f [open ${destroot}${prefix}/bin/az w 0755]
    puts $f "#!/bin/sh"
    puts $f "# MacPorts-installed wrapper for the Microsoft Azure CLI."
    puts $f "PYTHONPATH=\"${az_libdir}\${PYTHONPATH:+:\$PYTHONPATH}\""
    puts $f "export PYTHONPATH"
    puts $f "export AZ_INSTALLER=MACPORTS"
    puts $f "exec ${prefix}/bin/python${py_ver} -m azure.cli \"\$@\""
    close $f

    # Install shell completion for bash and zsh.
    xinstall -d ${destroot}${prefix}/etc/bash_completion.d
    set f [open ${destroot}${prefix}/etc/bash_completion.d/az w 0644]
    puts $f "eval \"\$(${prefix}/bin/python${py_ver} -m argcomplete.shellintegration --shell bash az)\""
    close $f
}

notes "
To enable bash completion for az, source the bash completion script in\
your shell rc file:

    . ${prefix}/etc/bash_completion.d/az

For zsh, add the following to your ~/.zshrc before any compinit call:

    autoload -U +X bashcompinit && bashcompinit
    . ${prefix}/etc/bash_completion.d/az
"

livecheck.type      pypi
livecheck.name      azure-cli
