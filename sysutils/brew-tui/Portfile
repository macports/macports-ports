# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0

name                brew-tui
version             0.1.0
revision            0
categories          sysutils
license             MIT
maintainers         {molinesdesigns.com:admin @MoLinesGitHub} openmaintainer
platforms           darwin

description         Visual TUI for Homebrew package management

long_description    Brew-TUI is a terminal UI for Homebrew built with React and \
                    Ink. Browse installed packages, search, upgrade, manage \
                    services, run brew doctor, and view package details from the \
                    terminal.

homepage            https://github.com/MoLinesGitHub/Brew-TUI

master_sites        https://registry.npmjs.org/brew-tui/-/
distname            brew-tui-${version}
extract.suffix      .tgz

checksums           rmd160  189484a8b2d1c6637f499affc5e0d76e60ee7585 \
                    sha256  4fa582ffbccd5e07eb00fccffedc7f35fd64d328ec5ab05aafa8bf83e08e0b03 \
                    size    108706

depends_lib         path:bin/node:nodejs20

use_configure       no

build {}

destroot {
    set worksrc ${worksrcpath}/package
    set installdir ${destroot}${prefix}/lib/node_modules/${name}

    xinstall -d ${installdir}
    copy {*}[glob ${worksrc}/*] ${installdir}

    system "cd ${installdir} && ${prefix}/bin/npm install --production --no-optional 2>/dev/null"

    xinstall -d ${destroot}${prefix}/bin
    ln -s ${prefix}/lib/node_modules/${name}/bin/brew-tui.js ${destroot}${prefix}/bin/brew-tui
}

notes "
Run 'brew-tui' to launch the terminal UI for Homebrew.
Run 'brew-tui status' to check your license status.
"
