                    build

destroot {
    xinstall -m 0755 \
        ${worksrcpath}/dist/${name} \
        ${destroot}${prefix}/bin/${name}-go

    xinstall -d ${destroot}${prefix}/share/man/man1

    xinstall -m 0644 \
        ${worksrcpath}/${name}.1 \
        ${destroot}${prefix}/share/man/man1/${name}-go.1
}

