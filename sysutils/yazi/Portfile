destroot {
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/${name} \
        ${worksrcpath}/target/[cargo.rust_platform]/release/ya      \
        ${destroot}${prefix}/bin/
    set comp_path(bash) ${destroot}${prefix}/share/bash-completion/completions/
    set comp_path(fish) ${destroot}${prefix}/share/fish/completions/
    set comp_path(zsh)  ${destroot}${prefix}/share/zsh/site-functions/
    foreach shell {bash fish zsh} {
        xinstall -d $comp_path(${shell})
    }
    xinstall -m 0644 ${worksrcpath}/${name}-boot/completions/${name}.bash $comp_path(bash)/${name}
    xinstall -m 0644 ${worksrcpath}/${name}-boot/completions/${name}.fish $comp_path(fish)/${name}.fish
    xinstall -m 0644 ${worksrcpath}/${name}-boot/completions/_${name} $comp_path(zsh)/_${name}
    xinstall -m 0644 ${worksrcpath}/${name}-cli/completions/ya.bash $comp_path(bash)/ya
    xinstall -m 0644 ${worksrcpath}/${name}-cli/completions/ya.fish $comp_path(fish)/ya.fish
    xinstall -m 0644 ${worksrcpath}/${name}-cli/completions/_ya $comp_path(zsh)/_ya
    xinstall -m 0644 ${distpath}/yazi.1 ${destroot}${prefix}/share/man/man1
    xinstall -m 0644 ${distpath}/yazi-config.5 ${destroot}${prefix}/share/man/man5
}

