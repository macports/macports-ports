                    size    4719616
github.tarball_from archive

post-destroot {
    set docdir ${prefix}/share/doc/${name}
    xinstall -d ${destroot}${docdir}
    xinstall -m 0644 -W ${worksrcpath} LICENSE.md README.md ${destroot}${docdir}
}

