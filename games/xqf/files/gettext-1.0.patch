Fix autogen failure when using gettext 1.0 ("Don't use gettext older than
0.10.38") by removing faulty code for obtaining gettext version and replace it
with a hardcoded number; MacPorts gettext is new enough for xqf.

https://github.com/XQF/xqf/issues/254
--- autogen.sh.orig	2014-11-01 19:43:18.000000000 -0500
+++ autogen.sh	2026-03-20 21:36:06.000000000 -0500
@@ -45,7 +45,7 @@
 rm -rf autom4te.cache
 
 # Ensure that gettext is reasonably new.
-gettext_ver=`$GETTEXTIZE --version | sed -n '1s/\.//g;1s/.* //;1s/^\(...\)$/\100/;1s/^\(...\)\(.\)$/\10\2/;1p'`
+gettext_ver=10000
 if test $gettext_ver -lt 01038; then
   echo "Don't use gettext older than 0.10.38" 2>&1
   exit 1
