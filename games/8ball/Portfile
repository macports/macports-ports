PortSystem          1.0
PortGroup           github 1.0

github.setup        ilianTsonev 8ball 1.0.1
github.tarball_from archive
categories          amusements
platforms           darwin
license             MIT
maintainers         @ilianTsonev openmaintainer

description         A simple Magic 8-Ball command line game.
long_description    ${description} It answers all your burning questions \
                    directly from your terminal.

if {${os.platform} eq "darwin" && ${os.major} < 16} {
    known_fail          yes
}

checksums           rmd160  0a81d743b4e302f76a833f4e2bbaa32bdd983aad \
                    sha256  85330f66a850577e50728a28134eca0a63f1cbd41539419e07f18fe1d9023d93 \
                    size    1627

use_configure       no

build {
    system -W ${worksrcpath} "swiftc main.swift -o 8ball"
}

destroot {
    xinstall -m 0755 ${worksrcpath}/8ball ${destroot}${prefix}/bin
}
