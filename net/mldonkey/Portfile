                    path:include/turbojpeg.h:libjpeg-turbo \
                    port:libmagic \
                    port:libpng \
                    path:lib/pkgconfig/librsvg-2.0.pc:librsvg \
                    port:miniupnpc \
                    port:ocaml \
                    port:ocaml-camlp4 \
                    port:ocaml-camlp-streams \
                    port:ocaml-num \
