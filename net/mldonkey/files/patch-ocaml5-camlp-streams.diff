+else
+  CAMLP_STREAMS_INC=
+  CAMLP_STREAMS_BYTE=
+  CAMLP_STREAMS_OPT=
+endif
+
+LIBS_byte=-custom unix.cma str.cma $(CAMLP_STREAMS_BYTE)
+LIBS_opt= unix.cmxa str.cmxa $(CAMLP_STREAMS_OPT)

-BIGARRAY_LIBS_opt=bigarray.cmxa
-BIGARRAY_LIBS_byte=bigarray.cma
+BIGARRAY_LIBS_opt=
+BIGARRAY_LIBS_byte=

 CRYPT_LIBS_opt=-cclib -lcrypt
@@ -93,7 +104,7 @@
 SUBDIRS=$(EXTLIB) $(CDK) $(BITSTRING) $(LIB) $(RSS) $(XML) $(NET) tools \
