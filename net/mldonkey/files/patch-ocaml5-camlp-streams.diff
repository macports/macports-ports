--- config/Makefile.in	2024-08-20 05:14:48
+++ config/Makefile.in	2026-06-07 00:00:00
@@ -28,10 +28,21 @@
 NO_STATIC_LIBS_opt=
 NO_CMXA=

-LIBS_byte=-custom bigarray.cma unix.cma str.cma
-LIBS_opt= bigarray.cmxa unix.cmxa str.cmxa
+CAMLP_STREAMS_PATH:=$(shell ocamlfind query camlp-streams 2>/dev/null)
