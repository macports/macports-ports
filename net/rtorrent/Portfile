configure.args      --mandir=${prefix}/share/man \
                    --disable-debug \
                    --enable-ipv6 \
                    --with-xmlrpc-c=no

variant xmlrpc description {Enable XMLRPC interface} {
    configure.args-delete   --with-xmlrpc-c=no
    configure.args-append   --with-xmlrpc-c
    depends_lib-append      port:xmlrpc-c
