PortSystem          1.0
PortGroup           github 1.0
PortGroup           active_variants 1.1
PortGroup           app 1.1
PortGroup           qt6 1.0

github.setup        XiaoYouChR Ghost-Downloader-3 3.8.1 v
github.tarball_from archive
revision            0
name                [string tolower [join [lrange [split ${github.project} -] 0 1] -]]
categories          net python
homepage            https://gd3.top
supported_archs     noarch
platforms           {darwin any}
license             GPL-3
maintainers         {i0ntempest @i0ntempest} openmaintainer

description         cross-platform QUIC AI-boost fluent-design multi-threaded downloader built with Python
long_description    {*}${description}

checksums           rmd160  0563de7ad13ac30a03ed6dd55dffdd5440eb8da4 \
                    sha256  ad6a5e9522869bb8512564df93682bcd83058ca65f98afd454681a48c08ac0ff \
                    size    13504271

set python_version  314
set python_branch   [string index ${python_version} 0].[string range ${python_version} 1 end]

# darkdetect[macos-listener] (1 extra dep)
# aioftp[socks] (1 extra dep)
# qrcode[png] (extra deps added its portfile)
# niquests[http3,socks,speedups] (extra deps added its portfile)
depends_lib-append \
                    port:python${python_version} \
                    port:py${python_version}-darkdetect \
                    port:py${python_version}-pyobjc \
                    port:py${python_version}-desktop-notifier \
                    port:libtorrent-rasterbar \
                    port:py${python_version}-loguru \
                    port:py${python_version}-niquests \
                    port:py${python_version}-orjson \
                    port:py${python_version}-pyside6 \
                    port:py${python_version}-pyside6-fluent-widgets \
                    port:py${python_version}-qrcode \
                    port:py${python_version}-uvloop \
                    port:py${python_version}-aioftp \
                    port:py${python_version}-siosocks

qt6.depends_lib     qttranslations

require_active_variants \
                    port:libtorrent-rasterbar python${python_version}

# Project does not have a typical Python project structure (pyproject.toml not usable for installation).
# deploy.py compiles and packs everything with nuitka into one app bundle - avoid that, make our own bundle.
# When last tested, deploy.py throws dependency scan error (possible Python 3.14 incompatibility) and
# permission errors (project tries to create Downloads/ folder in macports user home) when called by macports.
post-patch {
    # add shebang
    system -W ${worksrcpath} "grep -q '^#!' ${github.project}.py || sed -i '' '1i\\\n#!${prefix}/bin/python${python_branch}\\\n\\\n' ${github.project}.py"
}

use_configure       no
build {}

app.executable      ${worksrcpath}/${github.project}.py
app.icon            ${worksrcpath}/app/assets/logo.icns
app.name            {*}[join [lrange [split ${github.project} -] 0 1] " "]
app.identifier      com.${github.author}.[join [lrange [split ${github.project} -] 0 1] -]

destroot {
    set copy_dest ${destroot}${applications_dir}/${app.name}.app/Contents/MacOS/
    copy ${worksrcpath}/app/ ${copy_dest}
    copy ${worksrcpath}/features/ ${copy_dest}
    # see FEATURE_PACK_BLACKLIST in deploy.py
    delete ${copy_dest}/features/jack_yao
}

variant media description {enable and install dependencies for media downloading support} {
    set ::ffmpeg_ver \
                    8
    depends_run-append \
                    port:ffmpeg${::ffmpeg_ver} \
                    port:n-m3u8dl-re

    post-patch {
        # change default ffmpeg directory
        reinplace "s|{QStandardPaths.writableLocation(QStandardPaths.StandardLocation.GenericDataLocation)}/GhostDownloader/FFmpeg|${prefix}/libexec/ffmpeg${::ffmpeg_ver}|g" \
            ${worksrcpath}/features/ffmpeg_pack/config.py
        # change default n-m3u8dl-re directory
        reinplace "s|{QStandardPaths.writableLocation(QStandardPaths.StandardLocation.GenericDataLocation)}/GhostDownloader/M3U8DL|${prefix}/bin|g" \
            ${worksrcpath}/features/m3u8_pack/config.py
    }
}

default_variants    +media
