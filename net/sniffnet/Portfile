post-patch {
    system -W ${worksrcpath}/resources/packaging/macos "/usr/libexec/PlistBuddy -c \"Set :CFBundleShortVersionString ${version}\" Info.plist"
    system -W ${worksrcpath}/resources/packaging/macos "/usr/libexec/PlistBuddy -c \"Set :CFBundleVersion ${git-commit}\" Info.plist"
    system -W ${worksrcpath}/resources/packaging/macos "/usr/libexec/PlistBuddy -c \"Add :LSMinimumSystemVersion string ${macosx_deployment_target}\" Info.plist"
}

destroot {
    # Build app bundle manually with provided plist
    set app_path ${applications_dir}/[string totitle ${name}].app/
    set dest_app_path ${destroot}${app_path}
    foreach d {Resources MacOS} {
        xinstall -d ${dest_app_path}/Contents/$d/
    }
    xinstall -m 0755 ${worksrcpath}/target/[cargo.rust_platform]/release/${name} ${dest_app_path}/Contents/MacOS/
    xinstall -m 0755 ${worksrcpath}/resources/packaging/macos/wrapper.sh ${dest_app_path}/Contents/MacOS/
    xinstall -m 0644 ${worksrcpath}/resources/packaging/macos/graphics/sniffnet.icns ${dest_app_path}/Contents/Resources/
    xinstall -m 0644 ${worksrcpath}/resources/packaging/macos/Info.plist ${dest_app_path}/Contents/
    set fp [open ${dest_app_path}/Contents/PkgInfo w]
    puts -nonewline ${fp} "APPL????"
    close ${fp}
    system -W ${destroot}${applications_dir} "/usr/bin/codesign --sign - --deep [string totitle ${name}].app"
    ln -s ${applications_dir}/[string totitle ${name}].app/Contents/MacOS/${name} ${destroot}${prefix}/bin/
}

