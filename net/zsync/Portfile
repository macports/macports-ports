destroot {
    xinstall -m 0755 -W ${worksrcpath}/bin ${name} zsyncmake ${destroot}${prefix}/bin/
    xinstall -m 644 -W ${worksrcpath} \
        man/zsyncmake.1 \
        man/${name}.1 \
        ${destroot}${prefix}/share/man/man1
}
