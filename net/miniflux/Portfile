    set mandir ${prefix}/share/man/man1
    xinstall -m 0755 -d ${destroot}${mandir}

    xinstall -m 0755 ${worksrcpath}/${name}     ${destroot}${prefix}/bin/
    xinstall -m 0644 ${worksrcpath}/${name}.1   ${destroot}${mandir}/
