destroot {
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/${name} \
        ${destroot}${prefix}/bin/

    # man page
    xinstall -m 0444 \
        ${worksrcpath}/gen/${name}.1 ${destroot}${prefix}/share/man/man1/

    # shell completions
    set comp_srcdir ${worksrcpath}/gen/completions

    xinstall -d ${destroot}${prefix}/share/bash-completion/completions
    copy ${comp_srcdir}/${name}.bash \
        ${destroot}${prefix}/share/bash-completion/completions/${name}

    xinstall -d ${destroot}${prefix}/share/fish/vendor_completions.d
    copy ${comp_srcdir}/${name}.fish \
        ${destroot}${prefix}/share/fish/vendor_completions.d

    xinstall -d ${destroot}${prefix}/share/zsh/site-functions
    copy ${comp_srcdir}/_${name} ${destroot}${prefix}/share/zsh/site-functions/
}

