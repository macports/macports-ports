PortSystem              1.0
PortGroup               cargo 1.0
PortGroup               github 1.0

github.setup            tombi-toml tombi 0.9.9 v
github.tarball_from     archive
revision                0
categories              textproc devel
license                 MIT
platforms               {darwin >= 18}
maintainers             {@commitmaniac} openmaintainer

description             TOML formatter, linter, and language server
long_description        ${name} is a ${description}, written in Rust.

homepage                https://tombi-toml.github.io/tombi/

checksums               ${distname}${extract.suffix} \
                        rmd160  fc9604db1178fbc0c63932ba5ce352be0ce20511 \
                        sha256  afc7bb6f33c77a6e56f77bb594f2a0173d9164c8566961b95322e04bc0a5555b \
                        size    10406691

# See: https://trac.macports.org/ticket/73654
depends_lib-append      port:libiconv

# Use --offline instead to allow patching correct version
# value before building
cargo.offline_cmd-replace \
                        --frozen --offline

post-patch {
    reinplace "s|0.0.0-dev|${version}|" ${worksrcpath}/Cargo.toml
}

build.args-append       --package ${name}-cli

post-build {
    set tombi_bin ${worksrcpath}/target/[cargo.rust_platform]/release/${name}
    foreach shell {bash fish zsh} {
        system -W ${worksrcpath} \
            "${tombi_bin} completion ${shell} > tombi.${shell}"
    }
}

destroot {
    xinstall -m 755 ${worksrcpath}/target/[cargo.rust_platform]/release/${name} \
        ${destroot}${prefix}/bin/

    set bash_comp_path ${destroot}${prefix}/share/bash-completion/completions
    xinstall -d ${bash_comp_path}
    xinstall -m 644 ${worksrcpath}/${name}.bash ${bash_comp_path}/${name}

    set fish_comp_path ${destroot}${prefix}/share/fish/vendor_completions.d
    xinstall -d ${fish_comp_path}
    xinstall -m 644 ${worksrcpath}/${name}.fish ${fish_comp_path}

    set zsh_comp_path ${destroot}${prefix}/share/zsh/site-functions
    xinstall -d ${zsh_comp_path}
    xinstall -m 644 ${worksrcpath}/${name}.zsh ${zsh_comp_path}/_${name}
}

