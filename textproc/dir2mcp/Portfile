# Lean, pure-Go build: no CGO and no bundled docling runtime. The version is
# injected into the symbol the runtime reads (internal/buildinfo.Version),
# mirroring .goreleaser.yaml and the Makefile.
build {
    system -W ${worksrcpath} \
        "CGO_ENABLED=0 ${go.bin} build \
            -ldflags \"-s -w -X github.com/dirstral/dir2mcp/internal/buildinfo.Version=v${version}\" \
            -o ${name} ./cmd/dir2mcp"
}

destroot {
    xinstall -m 0755 ${worksrcpath}/${name} ${destroot}${prefix}/bin/${name}
}

# Smoke check: the built binary runs. dir2mcp has no `help` subcommand, so use
# `version` (printing usage on no-args would exit non-zero).
test.run            yes
test {
    system "${destroot}${prefix}/bin/${name} version"
}
